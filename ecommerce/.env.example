# Runtime serverless: transaction pooler PostgreSQL (Supabase: porta 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"
# Migrazioni: opzionale, solo se vuoi forzare una connessione diversa da DATABASE_URL.
MIGRATION_DATABASE_URL=""
DIRECT_URL=""
DATABASE_CONNECTION_LIMIT="1"
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
SESSION_SECRET=""
ADMIN_SETUP_TOKEN=""

# Analytics opzionale
NEXT_PUBLIC_GA_ID=""

# Pagamenti Stripe (opzionale: se assenti resta attivo il pagamento manuale)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email SMTP (opzionale: se assente le email restano in coda / log)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Sessa 1930 <no-reply@sessa1930.com>"

# Solo seed/demo. In produzione configurare sempre valori forti e non riusare i fallback locali.
SEED_ADMIN_PASSWORD=""
SEED_CUSTOMER_PASSWORD=""
